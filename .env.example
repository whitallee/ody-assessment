# Neon Postgres — direct (non-pooled) URL for Drizzle migrations
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon Postgres — pooled URL used by Cloudflare Workers at runtime
DATABASE_URL_POOLED=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Dashboard — public API base URL (local or deployed Workers URL)
EXPO_PUBLIC_API_URL=http://localhost:8787
